        <button class="btn wt-relationship-swap" type="button" data-wt-swap-individuals-button data-wt-swap-first="#xref" data-wt-swap-second="#xref2" data-wt-swap-form=".wt-page-options-relationships-chart" title="<?= e(I18N::translate('Swap individuals')) ?>">
            <span aria-hidden="true">⇄</span>
            <span class="visually-hidden"><?= I18N::translate('Swap individuals') ?></span>
